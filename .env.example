DATABASE_URL="postgresql://postgres:postgres@localhost:5432/seedance_studio"
REDIS_URL="redis://localhost:6379"

# 身分驗證（NextAuth）。NEXTAUTH_SECRET 用 `openssl rand -base64 32` 產生。
# ADMIN_EMAILS 是逗號分隔的管理員 Email，只有他們能進設定頁與改 API 金鑰。
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://127.0.0.1:3000"
ADMIN_EMAILS="you@example.com"

OPENAI_API_KEY="sk-..."
OPENAI_STORY_MODEL="gpt-5.4-mini"
OPENAI_PROMPT_MODEL="gpt-5.4-mini"
OPENAI_IMAGE_MODEL="gpt-image-2"
# whisper-1 會輸出含時間戳的逐字稿；gpt-4o-transcribe 則為純文字逐字稿。
OPENAI_TRANSCRIBE_MODEL="gpt-4o-transcribe"
ARK_API_KEY="your-byteplus-modelark-key"
ARK_BASE_URL="https://ark.ap-southeast.bytepluses.com/api/v3"
SEEDANCE_MODEL="dreamina-seedance-2-0-260128"

# 分鏡圖與成品影片放在 S3 相容物件儲存（例：Cloudflare R2）
# 因為 Web 與 Worker 是分開的服務、各自的本機磁碟不共用，必須透過物件儲存交換檔案。
S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="lurevid"
S3_ACCESS_KEY_ID="your-access-key-id"
S3_SECRET_ACCESS_KEY="your-secret-access-key"
S3_PUBLIC_URL="https://your-public-bucket-domain"
S3_FORCE_PATH_STYLE="false"

# Worker 合成影片時的本機暫存目錄
STORAGE_DIR="./storage/generated"

# Worker 並行設定（選填）
WORKER_CONCURRENCY="1"
IMAGE_CONCURRENCY="3"
SEEDANCE_CONCURRENCY="3"

# Seedance 輪詢（選填）：間隔與整體逾時（毫秒）
SEEDANCE_POLL_INTERVAL_MS="8000"
SEEDANCE_POLL_TIMEOUT_MS="1200000"
