generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  DRAFT
  QUEUED
  ANALYZING
  ANALYSIS_READY
  STRUCTURING
  STRUCTURE_READY
  ADAPTING
  ADAPT_READY
  STORYBOARDING
  STORYBOARD_READY
  GENERATING
  MERGING
  COMPLETED
  FAILED
}

enum SceneStatus {
  DRAFT
  PROMPT_READY
  IMAGE_GENERATING
  IMAGE_READY
  QUEUED
  GENERATING
  SUCCEEDED
  FAILED
}

model Project {
  id               String        @id @default(cuid())
  idea             String        @default("")
  sourceUrl        String?
  sourcePlatform   String?
  sourceTranscript String?       @db.Text
  analysis         String?       @db.Text
  structure        String?       @db.Text
  adaptedScript    String?       @db.Text
  status           ProjectStatus @default(DRAFT)
  message          String        @default("等待開始")
  progress         Float         @default(0)
  ratio            String        @default("9:16")
  resolution       String        @default("720p")
  duration         Int           @default(5)
  finalVideoUrl    String?
  error            String?
  scenes           Scene[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Scene {
  id              String      @id @default(cuid())
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sceneNumber     Int
  title           String
  visualGoal      String
  imagePrompt     String?     @db.Text
  imageUrl        String?
  imageLocalPath  String?
  seedancePrompt  String      @db.Text
  status          SceneStatus @default(DRAFT)
  seedanceTaskId  String?
  videoUrl        String?
  localPath       String?
  error           String?
  raw             Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([projectId, sceneNumber])
}

model AppSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
